generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  githubId      String?   @unique @map("github_id")
  githubUrl     String?   @map("github_url")
  bio           String?
  stripeCustomerId String? @unique @map("stripe_customer_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  sessions           Session[]
  completions        ChallengeCompletion[]
  projects           SharedProject[]
  authoredChallenges Challenge[]        @relation("AuthoredChallenges")
  challengeLikes     ChallengeLike[]
  challengeComments  ChallengeComment[]
  registrations      ChallengeRegistration[]
  stats              UserStats?
  achievements       UserAchievement[]
  apiKeys            ApiKey[]
  projectLikes       SharedProjectLike[]
  learningPaths      LearningPath[]
  billingAccount     BillingAccount?
  billingCheckouts   BillingCheckoutSession[]
  billingSubscriptions BillingSubscription[]
  creditLedgerEntries CreditLedgerEntry[]
  aiUsageRecords     AiUsageRecord[]
  postedJobs         Job[]               @relation("PostedJobs")
  jobApplications    JobApplication[]    @relation("JobApplications")
  marketplaceItems   MarketplaceItem[]     @relation("MarketplaceSeller")
  marketplaceReviews MarketplaceReview[]
  marketplacePurchases MarketplacePurchase[]
  emailSendLogs    EmailSendLog[]  @relation("emailSendLogs")
  activities           Activity[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?     @db.Text
  icon        String?
  color       String?
  order       Int         @default(0)
  isOfficial  Boolean     @default(false) @map("is_official")
  challenges  Challenge[]
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("categories")
}

model Tag {
  id         String         @id @default(cuid())
  name       String         @unique
  challenges ChallengeTag[]

  @@map("tags")
}

model ChallengeTag {
  challengeId String    @map("challenge_id")
  tagId       String    @map("tag_id")
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([challengeId, tagId])
  @@map("challenge_tags")
}

model LearningPath {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String      @db.Text
  icon        String
  color       String
  order       Int         @default(0)
  challenges  Challenge[]
  createdAt   DateTime    @default(now()) @map("created_at")
  authorId    String?     @map("author_id")
  author      User?       @relation(fields: [authorId], references: [id])
  isOfficial  Boolean     @default(false) @map("is_official")
  isPublished Boolean     @default(false) @map("is_published")

  @@map("learning_paths")
}

model Challenge {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  description   String     @db.Text
  difficulty    Difficulty
  objectives    String[]
  hints         String[]
  resources     String[]
  estimatedTime String?    @map("estimated_time")
  knowledgeContent String?  @db.Text @map("knowledge_content")
  isDraft          Boolean  @default(false) @map("is_draft")
  order         Int        @default(0)

  isOfficial    Boolean    @default(false) @map("is_official")
  authorId      String?    @map("author_id")
  author        User?      @relation("AuthoredChallenges", fields: [authorId], references: [id])
  forkedFromId  String?    @map("forked_from_id")
  forkedFrom    Challenge? @relation("Forks", fields: [forkedFromId], references: [id])
  forks         Challenge[] @relation("Forks")
  likesCount    Int        @default(0) @map("likes_count")

  categoryId    String?    @map("category_id")
  category      Category?  @relation(fields: [categoryId], references: [id])

  pathId        String?    @map("path_id")
  path          LearningPath? @relation(fields: [pathId], references: [id])

  tags          ChallengeTag[]
  completions   ChallengeCompletion[]
  projects      SharedProject[]
  likes         ChallengeLike[]
  comments      ChallengeComment[]
  registrations ChallengeRegistration[]
  translations        ChallengeTranslation[]
  activityChallenges  ActivityChallenge[]

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("challenges")
}

model ChallengeTranslation {
  id          String    @id @default(cuid())
  challengeId String    @map("challenge_id")
  locale      String
  title       String
  description String    @db.Text
  objectives  String[]
  hints       String[]
  knowledgeContent String?  @db.Text @map("knowledge_content")
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, locale])
  @@map("challenge_translations")
}

model ChallengeCompletion {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  challengeId String           @map("challenge_id")
  status      CompletionStatus @default(IN_PROGRESS)
  completedAt DateTime?        @map("completed_at")
  reflection  String?          @db.Text
  isPublic    Boolean          @default(true) @map("is_public")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("challenge_completions")
}

model SharedProject {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  challengeId String?   @map("challenge_id")
  title       String
  description String    @db.Text
  githubUrl   String    @map("github_url")
  demoUrl     String?   @map("demo_url")
  thumbnail   String?
  imageUrl    String?   @map("image_url")
  tags        String[]
  likes       Int       @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge    Challenge?          @relation(fields: [challengeId], references: [id])
  projectLikes SharedProjectLike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("shared_projects")
}

model SharedProjectLike {
  userId    String        @map("user_id")
  projectId String        @map("project_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   SharedProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")

  @@id([userId, projectId])
  @@map("shared_project_likes")
}

model ChallengeLike {
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([userId, challengeId])
  @@map("challenge_likes")
}

model ChallengeRegistration {
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([userId, challengeId])
  @@map("challenge_registrations")
}

model ChallengeComment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("challenge_comments")
}

model UserStats {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  xp             Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("user_stats")
}

model Achievement {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String
  icon        String
  xpReward    Int               @default(0) @map("xp_reward")
  rarity      AchievementRarity @default(COMMON)
  unlockedBy  UserAchievement[]
  createdAt   DateTime          @default(now()) @map("created_at")

  @@map("achievements")
}

model UserAchievement {
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String    @default("Default")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  usageRecords AiUsageRecord[]

  @@map("api_keys")
}

model BillingAccount {
  id                          String              @id @default(cuid())
  userId                      String              @unique @map("user_id")
  balanceMicrocredits         BigInt              @default(0) @map("balance_microcredits")
  lifetimeCreditedMicrocredits BigInt             @default(0) @map("lifetime_credited_microcredits")
  lifetimeDebitedMicrocredits BigInt              @default(0) @map("lifetime_debited_microcredits")
  createdAt                   DateTime            @default(now()) @map("created_at")
  updatedAt                   DateTime            @updatedAt @map("updated_at")

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries CreditLedgerEntry[]
  checkouts     BillingCheckoutSession[]
  subscriptions BillingSubscription[]
  usageRecords  AiUsageRecord[]

  @@map("billing_accounts")
}

model CreditProduct {
  id                  String             @id @default(cuid())
  code                String             @unique
  name                String
  description         String?            @db.Text
  type                BillingProductType
  billingInterval     BillingInterval    @default(ONE_TIME) @map("billing_interval")
  currency            String             @default("usd")
  unitAmount          Int                @map("unit_amount")
  creditsMicrocredits BigInt             @map("credits_microcredits")
  bonusMicrocredits   BigInt             @default(0) @map("bonus_microcredits")
  stripeProductId     String?            @map("stripe_product_id")
  stripePriceId       String?            @unique @map("stripe_price_id")
  active              Boolean            @default(true)
  sortOrder           Int                @default(0) @map("sort_order")
  metadata            Json?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  checkouts     BillingCheckoutSession[]
  subscriptions BillingSubscription[]

  @@map("credit_products")
}

model BillingCheckoutSession {
  id                      String                @id @default(cuid())
  userId                  String                @map("user_id")
  billingAccountId        String                @map("billing_account_id")
  productId               String                @map("product_id")
  stripeCheckoutSessionId String                @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?               @unique @map("stripe_payment_intent_id")
  stripeInvoiceId         String?               @unique @map("stripe_invoice_id")
  status                  BillingCheckoutStatus @default(PENDING)
  amountTotal             Int?                  @map("amount_total")
  currency                String                @default("usd")
  creditsGrantedMicrocredits BigInt             @default(0) @map("credits_granted_microcredits")
  completedAt             DateTime?             @map("completed_at")
  expiresAt               DateTime?             @map("expires_at")
  metadata                Json?
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount      @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  product        CreditProduct       @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerEntries  CreditLedgerEntry[]

  @@index([userId, status])
  @@map("billing_checkout_sessions")
}

model BillingSubscription {
  id                   String                    @id @default(cuid())
  userId               String                    @map("user_id")
  billingAccountId     String                    @map("billing_account_id")
  productId            String                    @map("product_id")
  stripeSubscriptionId String                    @unique @map("stripe_subscription_id")
  stripeCustomerId     String                    @map("stripe_customer_id")
  stripeLatestInvoiceId String?                  @map("stripe_latest_invoice_id")
  status               BillingSubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?                 @map("current_period_start")
  currentPeriodEnd     DateTime?                 @map("current_period_end")
  cancelAtPeriodEnd    Boolean                   @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?                 @map("canceled_at")
  metadata             Json?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount      @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  product        CreditProduct       @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerEntries  CreditLedgerEntry[]

  @@index([userId, status])
  @@map("billing_subscriptions")
}

model StripeWebhookEvent {
  id            String                  @id @default(cuid())
  stripeEventId String                  @unique @map("stripe_event_id")
  type          String
  status        StripeWebhookEventStatus @default(PROCESSED)
  payload       Json?
  errorMessage  String?                 @db.Text @map("error_message")
  processedAt   DateTime                @default(now()) @map("processed_at")
  createdAt     DateTime                @default(now()) @map("created_at")

  @@map("stripe_webhook_events")
}

model AiModelPricing {
  id                            String   @id @default(cuid())
  provider                      String
  model                         String
  displayName                   String?  @map("display_name")
  active                        Boolean  @default(true)
  promptMicrocreditsPerMillion  BigInt   @default(0) @map("prompt_microcredits_per_million")
  completionMicrocreditsPerMillion BigInt @default(0) @map("completion_microcredits_per_million")
  cacheWriteMicrocreditsPerMillion BigInt @default(0) @map("cache_write_microcredits_per_million")
  cacheReadMicrocreditsPerMillion BigInt  @default(0) @map("cache_read_microcredits_per_million")
  minimumChargeMicrocredits     BigInt   @default(0) @map("minimum_charge_microcredits")
  metadata                      Json?
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  usageRecords AiUsageRecord[]

  @@unique([provider, model])
  @@index([active])
  @@map("ai_model_pricing")
}

model AiUsageRecord {
  id                   String        @id @default(cuid())
  userId               String        @map("user_id")
  billingAccountId     String        @map("billing_account_id")
  apiKeyId             String?       @map("api_key_id")
  pricingId            String?       @map("pricing_id")
  externalId           String?       @unique @map("external_id")
  provider             String
  model                String
  inputTokens          BigInt        @default(0) @map("input_tokens")
  outputTokens         BigInt        @default(0) @map("output_tokens")
  cacheWriteTokens     BigInt        @default(0) @map("cache_write_tokens")
  cacheReadTokens      BigInt        @default(0) @map("cache_read_tokens")
  totalTokens          BigInt        @default(0) @map("total_tokens")
  chargedMicrocredits  BigInt        @default(0) @map("charged_microcredits")
  status               AiUsageStatus @default(COMPLETED)
  pricingSnapshot      Json?         @map("pricing_snapshot")
  metadata             Json?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  apiKey         ApiKey?        @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  pricing        AiModelPricing? @relation(fields: [pricingId], references: [id], onDelete: SetNull)
  ledgerEntry    CreditLedgerEntry?

  @@index([userId, createdAt])
  @@index([provider, model])
  @@map("ai_usage_records")
}

model CreditLedgerEntry {
  id                     String                 @id @default(cuid())
  userId                 String                 @map("user_id")
  billingAccountId       String                 @map("billing_account_id")
  aiUsageId              String?                @unique @map("ai_usage_id")
  checkoutSessionId      String?                @map("checkout_session_id")
  subscriptionId         String?                @map("subscription_id")
  type                   CreditLedgerEntryType
  source                 CreditLedgerEntrySource
  sourceRef              String?                @map("source_ref")
  amountMicrocredits     BigInt                 @map("amount_microcredits")
  balanceAfterMicrocredits BigInt               @map("balance_after_microcredits")
  description            String?                @db.Text
  metadata               Json?
  createdAt              DateTime               @default(now()) @map("created_at")

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount         @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  aiUsage        AiUsageRecord?         @relation(fields: [aiUsageId], references: [id], onDelete: SetNull)
  checkoutSession BillingCheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  subscription   BillingSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([source, sourceRef])
  @@index([userId, createdAt])
  @@map("credit_ledger_entries")
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ActivityType {
  HACKATHON
  THEMED
  EXTERNAL
  GENERAL
}

enum ActivityStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ENDED
}

enum CompletionStatus {
  IN_PROGRESS
  COMPLETED
}

enum BillingProductType {
  TOP_UP
  MEMBERSHIP
}

enum BillingInterval {
  ONE_TIME
  MONTH
  YEAR
}

enum BillingCheckoutStatus {
  PENDING
  COMPLETED
  EXPIRED
  FAILED
}

enum BillingSubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum StripeWebhookEventStatus {
  PROCESSED
  IGNORED
  FAILED
}

enum CreditLedgerEntryType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
  EXPIRE
}

enum CreditLedgerEntrySource {
  TOP_UP
  MEMBERSHIP
  AI_USAGE
  MANUAL_ADJUSTMENT
  REFUND
  PROMOTION
}

enum AiUsageStatus {
  COMPLETED
  FAILED
  REFUNDED
}

// ── Jobs Module ──

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobLocationType {
  REMOTE
  ONSITE
  HYBRID
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum JobApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Job {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  description     String          @db.Text
  company         String
  companyUrl      String?         @map("company_url")
  companyLogo     String?         @map("company_logo")
  location        String?
  locationType    JobLocationType @default(REMOTE) @map("location_type")
  type            JobType         @default(FULL_TIME)
  salaryMin       Int?            @map("salary_min")
  salaryMax       Int?            @map("salary_max")
  salaryCurrency  String          @default("USD") @map("salary_currency")
  skills          String[]
  contactEmail    String?         @map("contact_email")
  applyUrl        String?         @map("apply_url")
  status          JobStatus       @default(OPEN)

  authorId        String          @map("author_id")
  author          User            @relation("PostedJobs", fields: [authorId], references: [id], onDelete: Cascade)

  applications    JobApplication[]

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("jobs")
}

model JobApplication {
  id          String               @id @default(cuid())
  jobId       String               @map("job_id")
  userId      String               @map("user_id")
  coverLetter String?              @db.Text @map("cover_letter")
  resumeUrl   String?              @map("resume_url")
  status      JobApplicationStatus @default(PENDING)

  job         Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User                 @relation("JobApplications", fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@unique([jobId, userId])
  @@index([userId, status])
  @@map("job_applications")
}

// ─── Marketplace ─────────────────────────────────────────────────

enum MarketplaceItemType {
  SKILL
  TEMPLATE
  PRODUCT
  SERVICE
}

enum MarketplaceItemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EmailTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EmailSendStatus {
  PENDING
  SENDING
  COMPLETED
  FAILED
}

model MarketplaceItem {
  id          String                @id @default(cuid())
  slug        String                @unique
  title       String
  description String                @db.Text
  longDescription String?           @db.Text @map("long_description")
  type        MarketplaceItemType
  status      MarketplaceItemStatus @default(DRAFT)

  price       Int                   @default(0)
  currency    String                @default("usd")

  imageUrl    String?               @map("image_url")
  demoUrl     String?               @map("demo_url")
  sourceUrl   String?               @map("source_url")

  tags        String[]
  features    String[]

  sellerId    String                @map("seller_id")
  seller      User                  @relation("MarketplaceSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  viewsCount     Int               @default(0) @map("views_count")
  salesCount     Int               @default(0) @map("sales_count")
  avgRating      Float             @default(0) @map("avg_rating")
  reviewsCount   Int               @default(0) @map("reviews_count")

  reviews        MarketplaceReview[]
  purchases      MarketplacePurchase[]

  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([type, status])
  @@index([sellerId])
  @@map("marketplace_items")
}

model MarketplaceReview {
  id        String          @id @default(cuid())
  rating    Int
  comment   String?         @db.Text
  userId    String          @map("user_id")
  itemId    String          @map("item_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([userId, itemId])
  @@map("marketplace_reviews")
}

model MarketplacePurchase {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  itemId    String          @map("item_id")
  price     Int
  currency  String          @default("usd")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@unique([userId, itemId])
  @@map("marketplace_purchases")
}

// ─── Activities ─────────────────────────────────────────────────

model Activity {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String          @db.Text
  coverImage  String?         @map("cover_image")

  type        ActivityType
  status      ActivityStatus

  startDate   DateTime?       @map("start_date")
  endDate     DateTime?       @map("end_date")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  externalUrl String?         @map("external_url")
  content     String?         @db.Text

  authorId    String          @map("author_id")
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  challenges  ActivityChallenge[]
  translations ActivityTranslation[]

  @@index([status])
  @@index([type])
  @@map("activities")
}

model ActivityChallenge {
  activityId  String          @map("activity_id")
  challengeId String          @map("challenge_id")
  order       Int             @default(0)
  activity    Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  challenge   Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([activityId, challengeId])
  @@map("activity_challenges")
}

model ActivityTranslation {
  id          String          @id @default(cuid())
  activityId  String          @map("activity_id")
  locale      String
  title       String
  description String          @db.Text
  content     String?         @db.Text
  activity    Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, locale])
  @@map("activity_translations")
}

model EmailTemplate {
  id          String              @id @default(cuid())
  name        String
  subject     String
  content     Json
  htmlContent String?             @map("html_content") @db.Text
  variables   String[]            @default([])
  status      EmailTemplateStatus @default(DRAFT)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  sendLogs    EmailSendLog[]

  @@map("email_templates")
}

model EmailSendLog {
  id              String          @id @default(cuid())
  templateId      String          @map("template_id")
  template        EmailTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  recipientFilter String          @map("recipient_filter")
  totalCount      Int             @map("total_count")
  successCount    Int             @default(0) @map("success_count")
  failCount       Int             @default(0) @map("fail_count")
  status          EmailSendStatus @default(PENDING)
  sentAt          DateTime?       @map("sent_at")
  sentById        String          @map("sent_by_id")
  sentBy          User            @relation("emailSendLogs", fields: [sentById], references: [id])
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([templateId])
  @@index([status])
  @@map("email_send_logs")
}
